# Copy to `.env` and fill in. Values can be taken from Firebase Console → Project settings,
# or from `google-services.json` (Android) mapped as below.
#
# EAS / cloud APK builds: `.env` is usually gitignored, so configure the same `EXPO_PUBLIC_FIREBASE_*`
# names in EAS (Project → Environment variables or `eas secret:create`) for the build profile you use.

# client[0].api_key[0].current_key
EXPO_PUBLIC_FIREBASE_API_KEY=
# Usually: {project_id}.firebaseapp.com
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# project_info.project_id
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# project_info.storage_bucket (required by Firebase JS even if you do not use Storage)
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# project_info.project_number
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# client[0].client_info.mobilesdk_app_id — prefer the Web app ID from Firebase if you add a Web app
EXPO_PUBLIC_FIREBASE_APP_ID=

# Local development: skip App Check (do not use in production).
EXPO_PUBLIC_SKIP_APPCHECK=1

# Optional: when App Check enforcement is on, register this token in Firebase Console (App Check → Debug tokens).
# EXPO_PUBLIC_APPCHECK_DEBUG_TOKEN=

# Point the client at emulators (optional).
# EXPO_PUBLIC_USE_FIREBASE_EMULATOR=1
# EXPO_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1
# EXPO_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
# EXPO_PUBLIC_AUTH_EMULATOR_HOST=127.0.0.1
# EXPO_PUBLIC_AUTH_EMULATOR_PORT=9099
